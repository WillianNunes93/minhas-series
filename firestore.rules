rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'willianabnuness@gmail.com';
    }

    function souAmigoAceito(donoUid) {
      return (exists(/databases/$(database)/documents/solicitacoesAmizade/$(donoUid + '_' + request.auth.uid)) &&
              get(/databases/$(database)/documents/solicitacoesAmizade/$(donoUid + '_' + request.auth.uid)).data.status == 'aceita')
          || (exists(/databases/$(database)/documents/solicitacoesAmizade/$(request.auth.uid + '_' + donoUid)) &&
              get(/databases/$(database)/documents/solicitacoesAmizade/$(request.auth.uid + '_' + donoUid)).data.status == 'aceita');
    }

    match /usuarios/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == userId);

      match /series/{serieId} {
        allow read: if request.auth != null
          && (
            (request.auth.uid == userId
              && get(/databases/$(database)/documents/usuarios/$(userId)).data.bloqueado != true)
            || souAmigoAceito(userId)
          );

        allow write: if request.auth != null
          && request.auth.uid == userId
          && get(/databases/$(database)/documents/usuarios/$(userId)).data.bloqueado != true;
      }

      match /notificacoes/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /atividades/{atividadeId} {
        // Leitura liberada pro dono e para amigos aceitos (mesmo critério de
        // /series) — alimenta o feed de atividade dos amigos. Escrita continua
        // só do dono: ninguém deve registrar atividade na conta de outra pessoa.
        allow read: if request.auth != null
          && (
            (request.auth.uid == userId
              && get(/databases/$(database)/documents/usuarios/$(userId)).data.bloqueado != true)
            || souAmigoAceito(userId)
          );

        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /{path=**}/series/{serieId} {
      allow read: if isAdmin();
    }

    match /solicitacoesAmizade/{id} {
      allow create: if request.auth != null
        && request.resource.data.remetente == request.auth.uid
        && id == request.resource.data.remetente + '_' + request.resource.data.destinatario;

      allow get: if request.auth != null
        && (id.matches(request.auth.uid + '_.*') || id.matches('.*_' + request.auth.uid));

      allow list: if request.auth != null
        && (resource.data.remetente == request.auth.uid || resource.data.destinatario == request.auth.uid);

      allow update: if request.auth != null
        && resource.data.destinatario == request.auth.uid
        && request.resource.data.status == 'aceita';

      allow delete: if request.auth != null
        && (id.matches(request.auth.uid + '_.*') || id.matches('.*_' + request.auth.uid));
    }

    match /indicacoes/{id} {
      allow create: if request.auth != null
        && request.resource.data.remetente == request.auth.uid
        && souAmigoAceito(request.resource.data.destinatario);

      allow read: if request.auth != null
        && (resource.data.remetente == request.auth.uid || resource.data.destinatario == request.auth.uid);

      allow update: if request.auth != null
        && resource.data.destinatario == request.auth.uid;

      allow delete: if request.auth != null
        && (resource.data.remetente == request.auth.uid || resource.data.destinatario == request.auth.uid);
    }
  }
}
